# =============================================================================
# Laravel
# =============================================================================
/node_modules
/public/build
/public/hot
/public/storage
/vendor
/storage/*.key
/storage/pail
/auth.json

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
!.env.example
.env.backup
.env.production

# =============================================================================
# Terraform
# =============================================================================
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfstate
terraform/*.tfstate.*

# =============================================================================
